# Ambiente Flask
FLASK_ENV=development
HOST=0.0.0.0
PYTHONPATH=/app

# Portas expostas
GATEWAY_PORT=80
FRONTEND_PORT=3000
MAP_SERVICE_PORT=5001
ANALYSIS_SERVICE_PORT=5002
ZABBIX_SERVICE_PORT=5003
ACCESS_POINT_SERVICE_PORT=5004

# Chaves e configuracoes
FRONTEND_SECRET_KEY=frontend_secret_key
GATEWAY_SECRET_KEY=zabbixtrack
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
GATEWAY_HTTP_TIMEOUT=120
GATEWAY_HTTP_RETRIES=10
GATEWAY_HTTP_BACKOFF_FACTOR=2.0
GATEWAY_HTTP_VERIFY_SSL=false
ANALYSIS_HTTP_TIMEOUT=120
ACCESS_POINT_HTTP_TIMEOUT=120
ACCESS_POINT_DATABASE_URI=sqlite:///access_points.db
ZABBIX_DATABASE_URI=sqlite:///zabbix_config.db
ZABBIX_CORS_ORIGINS=http://localhost:3000,https://localhost:3000
ZABBIX_SSL_DIR=/app/ssl
ZABBIX_SSL_CERT_PATH=/app/ssl/cert.pem
ZABBIX_SSL_KEY_PATH=/app/ssl/key.pem

# URLs internas entre containers
GATEWAY_URL=http://gateway:80
FRONTEND_SERVICE_URL=http://frontend_service:3000
MAP_SERVICE_URL=http://map_service:5001
ANALYSIS_SERVICE_URL=http://analysis_service:5002
ZABBIX_SERVICE_URL=https://zabbix_service:5003
ACCESS_POINT_SERVICE_URL=http://access_point_service:5004
